{
  "name": "geezer-marketing",
  "version": "0.1.0",
  "description": "Geezer Collection marketing automation — Email, SMS, WhatsApp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "ioredis": "^5.3.2",
    "postgres": "^3.4.4",
    "resend": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
